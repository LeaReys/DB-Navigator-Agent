# DB Navigator Agent — шаблон конфигурации

# ============================================================
# LLM-провайдер: выберите один
# ============================================================
USE_OLLAMA=false

# -- OpenRouter (по умолчанию) --
OPENROUTER_API_KEY=
# Модели можно не трогать — подставятся бесплатные по умолчанию:
#OPENROUTER_MODEL_SMALL=nvidia/nemotron-nano-9b-v2:free
#OPENROUTER_MODEL_LARGE=nvidia/nemotron-nano-9b-v2:free

# -- Ollama (если USE_OLLAMA=true) --
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL_SMALL=llama3.1:8b
# OLLAMA_MODEL_LARGE=deepseek-coder-v2:16b
# OLLAMA_THINK=false

# ============================================================
# Hugging Face — для эмбеддингов 
# ============================================================

#HF_TOKEN=

# ============================================================
# LangFuse — трейсинг (необязательно, агент работает без него)
# ============================================================
# Ключи: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# SQL Server — сервер 1
# Локально:  DB_SERVER_1_HOST=localhost, PORT=14333
# В Docker:  DB_SERVER_1_HOST=mssql,     PORT=1433
# ============================================================
DB_SERVER_1_ALIAS=demo
DB_SERVER_1_HOST=localhost
DB_SERVER_1_PORT=14333
DB_SERVER_1_USERNAME=agent_reader
DB_SERVER_1_PASSWORD=Agent_ReadOnly_123!
DB_SERVER_1_DATABASES=db_proglib

# Дополнительные серверы (при необходимости):
# DB_SERVER_2_ALIAS=prod
# DB_SERVER_2_HOST=192.168.1.10
# ...
